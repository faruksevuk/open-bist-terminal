# Open BIST Terminal - ortam degiskenleri OPSIYONELDIR.
# Bu dosyayi kopyalamak ZORUNDA degilsin: varsayilan ayarlarla calisir.
#   - Veritabani: SQLite (backend/bist.db) otomatik olusur.
#   - AI anahtarlari: Ayarlar sekmesinden girilir (bist.db'de saklanir, git'e girmez).
#
# Asagidakiler yalnizca gelismis override icindir. Kullanmak istersen bu dosyayi
# ".env" olarak kopyala ve ilgili satiri ac.

# Postgres kullan (varsayilan SQLite yerine; ayrica: pip install -e ".[postgres]"):
# DATABASE_URL=postgresql+psycopg://kullanici:parola@host:5432/veritabani

# Log seviyesi (varsayilan INFO):
# LOG_LEVEL=DEBUG
